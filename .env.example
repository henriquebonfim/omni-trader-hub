# OmniTrader Environment Configuration
# =====================================

# --- API Authentication ---
# Authentication key for the backend API and Dashboard.
# If left empty, a random key will be generated on startup and shown in logs.
OMNITRADER_API_KEY=

# --- Exchange Credentials ---
# Binance Futures API keys. Only required if paper_mode is set to False in config.py.
# Testnet: https://testnet.binancefuture.com/
# Live: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET=

# --- Database (Memgraph) ---
# Graph database for market intelligence and strategy context.
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# --- Infrastructure (Redis) ---
# Used for Celery task brokerage and result storage, plus AI state caching.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1

# --- AI & Intelligence ---
# Ollama configuration for NLP and market narrative generation.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b

# CryptoCompare API Key for news ingestion (Free tier available).
# Get from: https://min-api.cryptocompare.com/pricing
CRYPTOCOMPARE_API_KEY=

# --- Notifications ---
# Discord Webhook for alerts (order execution, liquidations, regime changes).
# Create at: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# --- Frontend & UI ---
# WebSocket URL for live data feed. Leave empty to use Vite proxy (recommended for local dev).
VITE_WS_URL=
