# OmniTrader Environment Configuration
# =====================================

# Discord Webhook for Alerts (optional but recommended)
# Create webhook: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Binance API Credentials (only needed when paper_mode: false)
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET=

# Database Configuration (Memgraph)
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# Redis Configuration (Celery broker/backend)
REDIS_HOST=redis
REDIS_PORT=6379

# API Authentication (optional but recommended)
# If set, trading-related API routes that modify orders/trades will require this key
# in the Authorization header. Note: endpoints such as `/api/balance` and
# `/api/position` are not currently protected by this key.
OMNITRADER_API_KEY=

# Frontend WebSocket URL for live feed
# Leave empty to use relative URL via Vite proxy (ws://localhost:3000/ws/live -> backend)
# For production, set to backend WebSocket URL: wss://api.example.com/ws/live
VITE_WS_URL=

# Note: Paper trading mode (default) uses simulated $10k balance
# and does NOT require API keys. Only add keys for live trading.
